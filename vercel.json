{
  "version": 2,
  "builds": [
    {
      "src": "api/server.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/server.py" },
    { "src": "/audio/(.*)", "dest": "api/server.py" },
    { "src": "/video/(.*)", "dest": "api/server.py" },
    { "src": "/(.*)", "dest": "index.html" }
  ]
}
